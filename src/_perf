# Strict (RAM) NVMe-optimized batching writeback configuration, with BFQ to
# prioritize foreground responsiveness.
#
# Currently assumes three things:
# - 8 GB RAM (for predictable storage write performance);
# - NVMe (handle at least ~1 GB write efficiently; SLC cache focused);
# - No swap and no OOM state.
# - Multi-core CPU to handle the overhead of using BFQ.
#
# Not recommended for systems with swap, dynamic near-OOM workload.
# WARNING: Also not recommended for unreliable systems / power loss.

for OBJ_PATH in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    OBJ=\
'performance
'
    __file_write_ow_soft;
done

OBJ=\
'bfq
'
OBJ_PATH='/sys/block/nvme0n1/queue/scheduler'
__file_write_ow_soft -no-avoid;

OBJ=\
'6
'
OBJ_PATH='/proc/sys/vm/dirty_background_ratio'
__file_write_ow_soft;

OBJ=\
'3000
'
OBJ_PATH='/proc/sys/vm/dirty_expire_centisecs'
__file_write_ow_soft;

OBJ=\
'12
'
OBJ_PATH='/proc/sys/vm/dirty_ratio'
__file_write_ow_soft;

OBJ=\
'3000
'
OBJ_PATH='/proc/sys/vm/dirty_writeback_centisecs'
__file_write_ow_soft;
