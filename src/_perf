# Strict (RAM) NVMe-optimized batching writeback configuration.
#
# Currently assumes two things:
# - NVMe (handle at least ~1 GiB write efficiently; SLC cache focused);
# - No swap and no OOM state.
#
# Not recommended for systems with swap, dynamic near-OOM workload.
# WARNING: Also not recommended for unreliable systems / power loss.

for OBJ_PATH in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    OBJ=\
'performance
'
    __file_write_ow_soft;
done

OBJ=\
