# Guarded because the files are never created by us; the configuration depends
# on Arch Linux system.

[ "$arch_linux" ] || return 0

OBJ=
OBJ_PATH='/etc/pulse/default.pa'
__ed -log "${TMPDIR:-/tmp}/_pulseaudio_conf" -- \
    -s \
    'load-module module-suspend-on-idle' \
    '#load-module module-suspend-on-idle'
OBJ="$OBJ"
OBJ_PATH='/etc/pulse/default.pa'
__file_write_ow_soft -color -log "${TMPDIR:-/tmp}/_pulseaudio_conf"
