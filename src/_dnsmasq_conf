# DNS stub resolver configuration

OBJ=\
'bind-interfaces
cache-size=2048
domain-needed
bogus-priv
no-resolv
no-poll
no-hosts
no-negcache
all-servers
'
if [ "$ipv6" ]; then
    OBJ="$OBJ"\
'listen-address=::1,127.0.0.1
server=2606:4700:4700::1111
server=2606:4700:4700::1001
server=1.1.1.1
server=1.0.0.1
'
else
    OBJ="$OBJ"\
'listen-address=127.0.0.1
server=1.1.1.1
server=1.0.0.1
'
fi
OBJ_PATH='/etc/dnsmasq.conf'
__file_write_ow_soft;
