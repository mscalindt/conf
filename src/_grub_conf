OBJ=\
'GRUB_PRELOAD_MODULES="part_gpt"
GRUB_TIMEOUT_STYLE=menu
GRUB_TERMINAL_INPUT=console
GRUB_GFXMODE=auto
GRUB_GFXPAYLOAD_LINUX=keep
GRUB_DISABLE_RECOVERY=true

GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_CMDLINE_LINUX="\
loglevel=3 nowatchdog mitigations=off processor.ignore_ppc=1 \
usbhid.mousepoll=1 tsc=unstable pcie_aspm=force usbcore.autosuspend=-1 \
pcie_aspm.policy=performance pcie_port_pm=off net.ifnames=0 \
ahci.mobile_lpm_policy=1 \
'
if [ ! "$ipv6" ]; then
    OBJ="$OBJ"\
'ipv6.disable=1 \
'
fi
if [ "$_25ju" ]; then
    OBJ="$OBJ"\
'i915.enable_psr=0 i915.enable_dc=0 intel_idle.max_cstate=1 \
'
fi
OBJ="$OBJ"\
'"
'
OBJ_PATH='/etc/default/grub'
__file_write_ow_soft;

__info -white - 'Re-install GRUB to apply any changes.'
