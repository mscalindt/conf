OBJ=\
'# Graphics; x11-related
output * adaptive_sync off
output * allow_tearing yes
output * max_render_time off

# Mouse movement switches focus
focus_follows_mouse always

# Pin programs to specific workspaces
assign [title="Steam"] 7
assign [class="steam"] 7
assign [app_id="featherpad"] 2
assign [app_id="emacs"] 2

# Tiling configuration for specific programs
for_window [app_id="sway-app-launcher"] \
    floating enable, sticky enable, resize set 30 ppt 60 ppt, border pixel 5
for_window [app_id="firefox"] \
    border none

# Touchpad configuration; libinput-related
input type:touchpad {
    dwt disabled
    tap enabled
}

# Keyboard configuration; libinput/x11-related
input type:keyboard {
    xkb_layout us,bg(phonetic)
    xkb_model pc86
    xkb_options grp:alt_shift_toggle
    repeat_delay 222
    repeat_rate 50
}

# Mouse configuration (disable acceleration); libinput/x11-related
input * {
    accel_profile flat
}

# Solid color as wallpaper
output * bg #241f31 solid_color

# Tiling configuration
default_border pixel
client.focused #0A75AD #0A75AD #0A75AD #0A75AD #0A75AD

# Font configuration
font pango:Cantarell 12

# Mouse cursor configuration
seat seat0 xcursor_theme Breeze

# Keybindings
floating_modifier Mod4 normal
bindsym Mod4+1 workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+6 workspace number 6
bindsym Mod4+7 workspace number 7
bindsym Mod4+8 workspace number 8
bindsym Mod4+q kill
bindsym Mod4+f fullscreen
bindsym Mod4+w move container to workspace 8
bindsym Mod4+e move container to workspace 7
bindsym Mod4+Shift+c reload
bindsym Mod4+Return exec /usr/bin/alacritty
bindsym Mod4+a exec /usr/bin/alacritty \
    --class sway-app-launcher -e /usr/bin/sway-launcher-desktop
bindsym Mod4+t exec /usr/bin/Telegram
bindsym Mod4+b exec /usr/bin/blueman-manager
bindsym Mod4+l exec /usr/bin/swaylock
bindsym Mod4+Shift+e exec /usr/bin/emacs
bindsym Mod4+Shift+q exec /home/$USER/.config/sway/fkill_sway
bindsym Mod4+Space exec /home/$USER/.config/sway/music_toggle
bindsym Mod4+z exec /usr/bin/pamixer -d5
bindsym Mod4+x exec /usr/bin/pamixer -i5
bindsym Mod4+c exec /usr/bin/brightnessctl s 5%-
bindsym Mod4+v exec /usr/bin/brightnessctl s 5%+
bindsym print exec /usr/bin/grim \
    -l 9 $(/usr/bin/date +'\''SS_%Y%m%d_%H%M%S.png'\'')
bindsym Mod4+p exec /usr/bin/grim \
    -l 9 -g "$(/usr/bin/slurp)" $(/usr/bin/date +'\''SS_%Y%m%d_%H%M%S.png'\'')
bindsym Mod4+Shift+p exec /usr/bin/grim \
    -l 9 -g "$(/usr/bin/slurp; /usr/bin/sleep 2.5)" \
    $(/usr/bin/date +'\''SS_%Y%m%d_%H%M%S.png'\'')
bindsym Mod4+h exec /usr/bin/grim \
    -g "$(/usr/bin/slurp -p)" -t ppm - | \
    /usr/bin/convert - -format '\''%[pixel:p{0,0}]'\'' txt:- | \
    /usr/bin/tail -n 1 | /usr/bin/cut -d '\'' '\'' -f 4 | /usr/bin/wl-copy -n

# Status bar configuration
bar {
    position top
    font pango:Source Code Pro 10
    colors {
        statusline #ffffff
        background #2b2e37
        inactive_workspace #32323200 #32323200 #5c5c5c
    }
}

# Other
exec_always /usr/bin/sh -c '\''rm -f "${TMPDIR:-/tmp}"/nettotal'\''
exec_always /home/$USER/.config/sway/import-gsettings
exec_always /home/$USER/.config/sway/wp-handler_sway
'
if [ "$arch_linux" ]; then
    OBJ="$OBJ"\
'exec /home/$USER/.config/sway/systemd-handler
'
fi
OBJ_PATH="$home/.config/sway/config"
__file_write_ow_soft \
    -uid "$uid" -gid "$gid" \
    -user "$user" -group "$group"
