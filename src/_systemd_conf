# Directly modifies config files and doesn't use *.d drop-ins, because I want
# to be aware of file changes and any breakage, which is expected of systemd.

OBJ=\
'options snd_hda_intel power_save=0 power_save_controller=N
'
OBJ_PATH='/etc/modprobe.d/99-snd_powersave.conf'
__file_write_ow_soft;

OBJ=\
'kernel.sysrq = 1
'
OBJ_PATH='/etc/sysctl.d/99-sysctl.conf'
__file_write_ow_soft;

OBJ=
OBJ_PATH='/etc/systemd/logind.conf'
__ed -log "${TMPDIR:-/tmp}/_systemd_conf" -- \
    -s \
    'HandlePowerKey=' \
    'HandlePowerKey=ignore' \
    -s \
    'HandleRebootKey' \
    'HandleRebootKey=ignore' \
    -s \
    'HandleRebootKeyLongPress=' \
    'HandleRebootKeyLongPress=ignore' \
    -s \
    'HandleSuspendKey=' \
    'HandleSuspendKey=ignore' \
    -s \
    'HandleSuspendKeyLongPress=' \
    'HandleSuspendKeyLongPress=ignore' \
    -s \
    'HandleHibernateKey=' \
    'HandleHibernateKey=ignore' \
    -s \
    'HandleLidSwitch=' \
    'HandleLidSwitch=ignore' \
    -s \
    'HandleLidSwitchExternalPower=' \
    'HandleLidSwitchExternalPower=ignore'
OBJ="$OBJ"
OBJ_PATH='/etc/systemd/logind.conf'
__file_write_ow_soft -color -log "${TMPDIR:-/tmp}/_systemd_conf" -sanit \
    -trunc
